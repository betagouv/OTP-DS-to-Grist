# =============================================================================
# CONFIGURATION POSTGRESQL
# =============================================================================

# Nom de la base de données (utilisé par le container Docker)
POSTGRES_DB=db_name

# Utilisateur PostgreSQL
POSTGRES_USER=user

# Mot de passe PostgreSQL
POSTGRES_PASSWORD=

# URL de connexion pour Docker
# NOTE: Avec network_mode: host, utiliser localhost:5433 (port exposé sur l'hôte)
DOCKER_DATABASE_URL=postgresql://user@localhost:5433/db_name

# URL de connexion pour développement local (sans Docker)
# NOTE: Utilise le port 5432 (port par défaut PostgreSQL)
DATABASE_URL=postgresql://user@localhost:5432/db_name

# =============================================================================
# CONFIGURATION API DÉMARCHES SIMPLIFIÉES
# =============================================================================

# URL de l'API GraphQL Démarches Simplifiées
DEMARCHES_API_URL=https://www.demarches-simplifiees.fr/api/v2/graphql

# Token API Démarches Simplifiées (généré depuis votre compte)
DEMARCHES_API_TOKEN=

# Numéro de la démarche à traiter
DEMARCHE_NUMBER=

# =============================================================================
# CONFIGURATION API GRIST
# =============================================================================

# Clé API Grist (générée depuis les paramètres Grist)
GRIST_API_KEY=

# ID du document Grist (visible dans l'URL du document)
GRIST_DOC_ID=

# =============================================================================
# CONFIGURATION AVANCÉE
# =============================================================================

# Taille des lots de traitement
BATCH_SIZE='50'

# Nombre de workers parallèles
MAX_WORKERS='3'

# Activer le traitement parallèle (True/False)
PARALLEL='True'

# Niveau de log: 0=minimal, 1=normal, 2=verbose
LOG_LEVEL=1

# =============================================================================
# FILTRES (OPTIONNELS)
# =============================================================================

# Filtrer les dossiers par date de dépôt (format: YYYY-MM-DD)
DATE_DEPOT_DEBUT=

# Filtrer les dossiers par date de dépôt (format: YYYY-MM-DD)
DATE_DEPOT_FIN=

# Filtrer par statuts (ex: accepte, en_instruction)
STATUTS_DOSSIERS=

# Filtrer par groupes d'instructeurs
GROUPES_INSTRUCTEURS=

# =============================================================================
# FLASK
# =============================================================================

# Clé secrète pour Flask (requis pour les sessions)
# Générez avec: poetry run poe generate-secret
FLASK_SECRET_KEY=changeme

# Mode debug Flask (True = développement, False = production)
FLASK_DEBUG=False

# =============================================================================
# ENCRYPTION
# =============================================================================

# Clé d'encryption pour les données sensibles
# Générez avec: poetry run poe generate-encryption-key
ENCRYPTION_KEY=

# =============================================================================
# SYNCHRONISATION (OPTIONNEL)
# =============================================================================

# Heure de synchronisation automatique (0-23)
SYNC_HOUR=11

# Minute de synchronisation automatique (0-59)
SYNC_MINUTE=14

# Version de l'application
APP_VERSION=0.6
